APP_ENV=production

# Public domain Caddy should serve
SHOP_DOMAIN=shop.example.com
ACME_EMAIL=ops@example.com

# Optional local-only admin port binding on host
ADMIN_LOCAL_PORT=8081

# Cookie and session secrets
COOKIE_SECURE=false
WEB_SESSION_SECRET=replace-with-long-random-string
ADMIN_SESSION_SECRET=replace-with-long-random-string
DOWNLOAD_TOKEN_SECRET=replace-with-long-random-string

# Order/payment behavior
ORDER_EXPIRY_MINUTES=1440
REQUIRED_CONFIRMATIONS=10
PAYMENT_POLL_INTERVAL_SECONDS=30
PUBLIC_BASE_URL=https://shop.example.com

# Monero wallet RPC credentials and wallet setup
WALLET_RPC_USERNAME=walletrpc
WALLET_RPC_PASSWORD=replace-with-strong-password
WALLET_FILE=store.wallet
WALLET_PASSWORD=replace-with-wallet-password
WALLET_AUTO_CREATE=false
WALLET_CREATE_LANGUAGE=English

# Public remote node address that wallet-rpc should use
# Example clearnet node: node.moneroworld.com:18089
# Example onion node: abcdefg123456789.onion:18089
MONERO_REMOTE_NODE=node.moneroworld.com:18089

# Admin bootstrap login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password
# Optional pre-hashed password (if set, it takes precedence)
ADMIN_PASSWORD_HASH=

# Optional override URL for the Monero CLI tarball downloaded in wallet container
MONERO_CLI_DOWNLOAD_URL=https://downloads.getmonero.org/cli/linux64
