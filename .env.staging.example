APP_ENV=staging

SHOP_DOMAIN=localhost
ACME_EMAIL=staging@example.com
ADMIN_LOCAL_PORT=18081

COOKIE_SECURE=false
WEB_SESSION_SECRET=staging-web-session-secret-change-me
ADMIN_SESSION_SECRET=staging-admin-session-secret-change-me
DOWNLOAD_TOKEN_SECRET=staging-download-token-secret-change-me

ORDER_EXPIRY_MINUTES=1440
REQUIRED_CONFIRMATIONS=5
PAYMENT_POLL_INTERVAL_SECONDS=30
PUBLIC_BASE_URL=https://localhost:8443
PRODUCT_IMAGES_DIR=/data/product_images

WALLET_RPC_USERNAME=walletrpc
WALLET_RPC_PASSWORD=staging-wallet-rpc-password
WALLET_FILE=store-stagenet.wallet
WALLET_PASSWORD=staging-wallet-file-password
WALLET_AUTO_CREATE=true
WALLET_CREATE_LANGUAGE=English
MONERO_NETWORK=stagenet

# Example stagenet remote node. Replace with a currently healthy stagenet node.
MONERO_REMOTE_NODE=stagenet.community.rino.io:38081
MONERO_REMOTE_NODES=stagenet.community.rino.io:38081

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_PASSWORD_HASH=

MONERO_CLI_DOWNLOAD_URL=https://downloads.getmonero.org/cli/linux64
TOR_SOCKS_DISABLED=true
