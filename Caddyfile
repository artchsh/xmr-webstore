{$SHOP_DOMAIN:localhost} {
    encode gzip zstd
    reverse_proxy webshop:8000

    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy no-referrer
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        -Server
    }
}
